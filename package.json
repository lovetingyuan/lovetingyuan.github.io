{
  "name": "tingyuan",
  "version": "0.0.0",
  "private": true,
  "description": "庭院的个人网站",
  "homepage": "https://lovetingyuan.github.io",
  "engines": {
    "node": ">=24.12.0"
  },
  "type": "module",
  "scripts": {
    "build": "npm run build:ssr && npm run build:client",
    "build:client": "cross-env NODE_ENV=production && vite build",
    "build:ssr": "cross-env NODE_ENV=production vite build --ssr src/server.ts --outDir dist-ssr",
    "dev": "vite",
    "format": "oxfmt",
    "knip": "npx -y knip@latest -c scripts/knip.ts",
    "lint": "oxlint . --fix",
    "preview": "vite preview",
    "serve": "vite preview",
    "type-check": "vue-tsc --build --force"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@vueuse/core": "^14.2.1",
    "github-markdown-css": "^5.9.0",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.4",
    "@iconify/vue": "^5.0.0",
    "@shikijs/markdown-it": "^4.0.2",
    "@total-typescript/ts-reset": "^0.6.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/markdown-it-container": "^4.0.0",
    "@types/markdown-it-link-attributes": "^3.0.5",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "daisyui": "^5.5.19",
    "html-minifier-terser": "^7.2.0",
    "knip": "^5.87.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-link-attributes": "^4.0.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tinypool": "^2.0.0",
    "typescript": "~5.9.3",
    "unplugin-detect-duplicated-deps": "^2.0.0",
    "unplugin-vue-markdown": "^30.0.0",
    "vite": "^8.0.5",
    "vite-plugin-pwa": "^1.2.0",
    "vue-tsc": "^3.2.6",
    "workbox-build": "^7.4.0",
    "workbox-window": "^7.4.0"
  }
}
